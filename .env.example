# RestUI — Variables d'environnement
# Copier en .env et remplir les valeurs réelles
# .env est gitignored — ne JAMAIS committer .env

# ─── Credentials API REST cible ─────────────────────────────────────────────
# Identifiants utilisés par le proxy httpx pour s'authentifier sur l'API interne
API_USERNAME=username
API_PASSWORD=changeme

# ─── Caddy Basic Auth (optionnel) ────────────────────────────────────────────
# Hash bcrypt du mot de passe — générer via :
#   docker run --rm caddy:latest caddy hash-password --plaintext "monMotDePasse"
# Décommenter dans Caddyfile pour activer
# CADDY_AUTH_PASSWORD_HASH=$2a$14$REMPLACER_PAR_UN_VRAI_HASH_BCRYPT

# ─── Config avancée (optionnel) ──────────────────────────────────────────────
# Timeout httpx en secondes (défaut : 10)
# HTTP_TIMEOUT=10

# Log level : DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
