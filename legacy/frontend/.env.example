# RestUI — Variables d'environnement frontend Astro
# Copier en .env et adapter

# URL du backend FastAPI — utilisée par les fetches SSR dans Layout.astro,
# index.astro et [endpoint].astro.
# En dev local    : http://localhost:8000
# En prod Docker  : http://restui-backend:8000  (injecté par docker-compose.yml)
BACKEND_URL=http://localhost:8000
