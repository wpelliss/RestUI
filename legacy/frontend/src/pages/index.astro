---
/**
 * index.astro — Dashboard RestUI
 *
 * SSR : données fraîches à chaque requête (prerender: false).
 * Grille de cartes cliquables, une par endpoint configuré.
 */

export const prerender = false;

import Layout from '../layouts/Layout.astro';

interface EndpointMeta {
  name: string;
  label: string;
  description?: string;
}

let endpoints: EndpointMeta[] = [];
let fetchError: string | null = null;

try {
  const backendUrl = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
  const res = await fetch(`${backendUrl}/api/endpoints`);
  if (res.ok) {
    endpoints = await res.json();
  } else {
    fetchError = `Le backend a répondu ${res.status}`;
  }
} catch {
  fetchError = 'Impossible de joindre le backend';
}
---

<Layout title="Dashboard" active="index">

  <div class="mb-6">
    <h2 class="text-xl font-semibold text-slate-800">Dashboard</h2>
    <p class="text-sm text-slate-500 mt-1">Sélectionne un endpoint pour explorer ses données.</p>
  </div>

  {fetchError && (
    <div class="flex items-center gap-3 px-4 py-3 mb-6 rounded-lg border border-red-200 bg-red-50 text-red-700 text-sm" role="alert">
      <!-- Heroicons: exclamation-circle -->
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="1.5" stroke="currentColor" class="w-5 h-5 flex-shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <span>{fetchError}</span>
    </div>
  )}

  {endpoints.length > 0 ? (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {endpoints.map((ep) => (
        <a
          href={`/${ep.name}`}
          class="
            group flex flex-col gap-3 p-5 rounded-xl bg-white border border-slate-200
            shadow-sm hover:shadow-md hover:border-blue-300
            transition-all duration-200 no-underline
          "
        >
          <div class="flex items-center justify-between">
            <div class="
              w-10 h-10 rounded-lg bg-blue-50 text-blue-600
              flex items-center justify-center
              group-hover:bg-blue-600 group-hover:text-white
              transition-colors duration-200
            ">
              <!-- Heroicons: table-cells (mini) -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                <path fill-rule="evenodd"
                  d="M.99 5.24A2.25 2.25 0 0 1 3.25 3h13.5A2.25 2.25 0 0 1 19.01 5.24l.527 4a2.25 2.25 0 0 1-2.236 2.516H2.7A2.25 2.25 0 0 1 .463 9.24l.527-4Zm4.01.51a.75.75 0 0 0-.75.75v2a.75.75 0 0 0 .75.75h3a.75.75 0 0 0 .75-.75v-2a.75.75 0 0 0-.75-.75H5ZM5 14.25a.75.75 0 0 0 0 1.5h10a.75.75 0 0 0 0-1.5H5Z"
                  clip-rule="evenodd" />
              </svg>
            </div>
            <!-- Heroicons: chevron-right (mini) -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                 class="w-4 h-4 text-slate-300 group-hover:text-blue-600 transition-colors duration-200">
              <path fill-rule="evenodd"
                d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z"
                clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-slate-800 text-sm leading-tight">{ep.label}</p>
            {ep.description && (
              <p class="text-xs text-slate-400 mt-1 leading-relaxed">{ep.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  ) : !fetchError ? (
    <div class="flex flex-col items-center justify-center gap-4 py-24 text-slate-400">
      <!-- Heroicons: folder-open -->
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="1.5" stroke="currentColor" class="w-12 h-12 opacity-40">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" />
      </svg>
      <p class="text-sm">Aucun endpoint configuré dans <code class="font-mono text-xs bg-slate-100 px-1 rounded">config.yaml</code>.</p>
    </div>
  ) : null}

</Layout>
