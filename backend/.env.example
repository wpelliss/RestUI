# .env.example — copier en .env et renseigner les valeurs réelles.
# Ce fichier est commité (pas de secrets). .env est dans .gitignore.

# ── Credentials HTTP Basic Auth pour l'API upstream ─────────────────────────
# Obligatoires — l'app refuse de démarrer si absents ou vides.
API_USERNAME=your_api_username
API_PASSWORD=your_api_password

# ── Timeouts httpx (secondes) ────────────────────────────────────────────────
# UPSTREAM_TIMEOUT_CONNECT=5.0
# UPSTREAM_TIMEOUT_READ=30.0

# ── Chemin vers le fichier YAML des endpoints (relatif au CWD) ───────────────
# CONFIG_YAML_PATH=config.yaml

# ── Mode debug — active /docs et les logs verbeux. Ne jamais mettre true en prod.
# DEBUG=false

# ── Niveau de log : debug, info, warning, error, critical ────────────────────
# LOG_LEVEL=info

# ── Hash bcrypt pour Basic Auth Caddy ────────────────────────────────────────
# Utilisé par Caddyfile si basic_auth est activé (option A).
# Générer : docker run --rm caddy:latest caddy hash-password --plaintext "motdepasse"
# CADDY_AUTH_PASSWORD_HASH=$2a$14$...
