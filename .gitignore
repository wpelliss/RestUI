# ─── Secrets — CRITIQUE ──────────────────────────────────────────────────────
# .env matche backend/.env et tout .env récursif (comportement gitignore standard)
.env
.env.local
.env.*.local

# config.yaml contient les URL API upstream.
# Gitignored par défaut car les URL peuvent révéler la topologie interne.
# Committer config.yaml est acceptable si l'équipe en a besoin et si les URL ne sont pas sensibles.
config.yaml

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python

# ─── Frontend (si ajout post-MVP) ────────────────────────────────────────────
node_modules/
.astro/
.svelte-kit/
.output/

# ─── Docker ──────────────────────────────────────────────────────────────────
# Ne pas ignorer docker-compose.yml — il ne doit pas contenir de secrets.
# Les secrets vivent dans backend/.env uniquement.

# ─── IDE / OS ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Coverage / tests ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
